# -----------------------------------------------------------------------------
# Atlas SI 2.2.0 — configuration générale
# Copier ce fichier en .env puis remplacer toutes les valeurs CHANGE_ME.
# Protéger ensuite le fichier : chmod 600 .env
# -----------------------------------------------------------------------------

APP_ENV=production
APP_NAME="Atlas SI"
APP_VERSION=2.2.0

# -----------------------------------------------------------------------------
# Publication Web
#
# Production HTTPS standard :
#   GATEWAY_SCHEME=https
#   GATEWAY_PORT=443
#   PUBLIC_BASE_URL=https://carto.example.org
#
# HTTPS sur un port différent :
#   GATEWAY_SCHEME=https
#   GATEWAY_PORT=8443
#   PUBLIC_BASE_URL=https://carto.example.org:8443
#
# Laboratoire sans certificat :
#   GATEWAY_SCHEME=http
#   GATEWAY_PORT=8080
#   PUBLIC_BASE_URL=http://serveur-lab.example.org:8080
#   COOKIE_SECURE=false
#   TLS_CERTIFICATE_FILE=
#   TLS_PRIVATE_KEY_FILE=
# -----------------------------------------------------------------------------
GATEWAY_SCHEME=https
GATEWAY_PORT=443
PUBLIC_BASE_URL=https://carto.example.org
PUBLIC_HOST=carto.example.org
TRUSTED_HOSTS=carto.example.org
TLS_CERTIFICATE_FILE=atlas-si.fullchain.pem
TLS_PRIVATE_KEY_FILE=atlas-si.key
APP_SECRET_KEY=CHANGE_ME_64_HEX_CHARS_MINIMUM
SESSION_TTL_HOURS=8
COOKIE_SECURE=true

POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD

# -----------------------------------------------------------------------------
# Images de conteneurs
# Les valeurs ci-dessous sont les versions testées avec Atlas SI 2.2.0.
# Les tags flottants (stable, lts, latest...) sont techniquement acceptés, mais
# déconseillés en production car ils peuvent changer sans modification du .env.
# -----------------------------------------------------------------------------
POSTGRES_IMAGE=postgres:18.4-alpine3.23
POSTGRES_DATA_PATH=/var/lib/postgresql
POSTGRES_VOLUME_NAME=atlas_postgres_data
PYTHON_IMAGE=python:3.13.14-slim-trixie
NODE_IMAGE=node:24.18.0-alpine3.23
NGINX_IMAGE=nginx:1.30.3-alpine3.23
ALLOW_LATEST_IMAGES=false

# -----------------------------------------------------------------------------
# Authentification : choisir UNE valeur parmi local ou keycloak.
# -----------------------------------------------------------------------------
AUTH_MODE=keycloak

# --- Mode local ---------------------------------------------------------------
# Utilisés uniquement lorsque AUTH_MODE=local.
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=CHANGE_ME_LOCAL_ADMIN_PASSWORD_MINIMUM_12_CHARS
LOCAL_ADMIN_DISPLAY_NAME="Administrateur Atlas SI"
LOCAL_ADMIN_EMAIL=
# Passer temporairement à true pour remplacer en base le mot de passe local
# par LOCAL_ADMIN_PASSWORD, puis remettre false après le déploiement.
LOCAL_ADMIN_RESET_PASSWORD=false
LOCAL_LOGIN_MAX_ATTEMPTS=5
LOCAL_LOGIN_WINDOW_SECONDS=900

# --- Mode Keycloak ------------------------------------------------------------
# Utilisés uniquement lorsque AUTH_MODE=keycloak.
# URL publique du realm, sans slash final.
OIDC_ISSUER_URL=https://CHANGE_ME/realms/CHANGE_ME
OIDC_CLIENT_ID=carto-app
OIDC_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_CLIENT_SECRET
OIDC_SCOPES="openid profile email"

# Les valeurs sont comparées sans tenir compte de la casse.
# Les groupes Keycloak peuvent être indiqués avec ou sans le chemin complet.
AUTH_ADMIN_VALUES=ATLAS-ADMINISTRATEURS,/ATLAS-ADMINISTRATEURS
AUTH_CONTRIBUTOR_VALUES=ATLAS-CONTRIBUTEURS,/ATLAS-CONTRIBUTEURS
AUTH_AUDITOR_VALUES=ATLAS-AUDITEURS,/ATLAS-AUDITEURS
AUTH_READER_VALUES=ATLAS-LECTEURS,/ATLAS-LECTEURS
ALLOW_AUTHENTICATED_READ=true

# Réglages de la cartographie. Une reconstruction du gateway est nécessaire.
MAP_WHEEL_SENSITIVITY=0.85
MAP_MIN_ZOOM=0.12
MAP_MAX_ZOOM=4.8
MAP_DEFAULT_THEME=light

FORWARDED_ALLOW_IPS=*
LOG_LEVEL=INFO

# Profil initial lors de la première installation : minimal ou complete.
# Une fois l'application démarrée, les modules se pilotent dans Administration > Fonctionnalités.
FEATURE_PROFILE=minimal
MAP_MAX_RECURSION_DEPTH=10
MAP_MAX_DISPLAYED_NODES=1200
